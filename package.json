{
  "name": "@makerx/node-winston",
  "version": "1.3.0",
  "private": false,
  "description": "A set of winston formats, console transport and logger creation functions",
  "author": "MakerX",
  "license": "MIT",
  "type": "module",
  "module": "index.mjs",
  "types": "index.d.ts",
  "main": "index.cjs",
  "engines": {
    "node": ">=16.0"
  },
  "bugs": {
    "url": "https://github.com/MakerXStudio/node-winston/issues"
  },
  "homepage": "https://github.com/MakerXStudio/node-winston#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MakerXStudio/node-winston.git"
  },
  "scripts": {
    "audit": "better-npm-audit audit",
    "format": "prettier --write .",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "check-types": "tsc -p tsconfig.json",
    "build": "run-s build:*",
    "build:0-clean": "rimraf dist coverage",
    "build:1-lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "build:2-check-types": "tsc -p tsconfig.json",
    "build:3-build": "rollup -c --configPlugin typescript",
    "build:4-copy-pkg-json": "tstk copy-package-json -c",
    "build:5-copy-readme": "copyfiles ./README.md ./dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter junit --outputFile test-results.xml"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@makerx/eslint-config": "4.2.0",
    "@makerx/node-common": "^1.5.0",
    "@makerx/prettier-config": "2.0.1",
    "@makerx/ts-toolkit": "^4.0.0-beta.24",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node20": "20.1.9",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.12",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-v8": "4.1.4",
    "better-npm-audit": "^3.11.0",
    "copyfiles": "^2.4.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "npm-run-all": "^4.1.5",
    "prettier": "3.8.2",
    "rimraf": "^6.1.3",
    "rollup": "4.60.1",
    "tslib": "^2.8.1",
    "tsx": "4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@colors/colors": ">=1",
    "lodash": ">=4",
    "logform": ">=2",
    "triple-beam": ">=1",
    "winston": ">=3",
    "winston-transport": ">=4",
    "yamlify-object": ">=1",
    "yamlify-object-colors": ">=1"
  }
}
